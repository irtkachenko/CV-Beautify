# Groq Configuration (server-side only)
GROQ_API_KEY=gsk_...
# Optional preferred model (defaults to a fallback chain if unavailable)
GROQ_MODEL=mixtral-8x7b-32768
# Optional comma-separated model fallback order override
# GROQ_MODELS=mixtral-8x7b-32768,llama-3.3-70b-versatile,llama-3.1-70b-versatile
